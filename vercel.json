{
  "version": 2,
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/client/public/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/client/public/$1"
    }
  ]
}